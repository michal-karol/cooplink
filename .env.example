# Core app
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgresql://cooplink:cooplink@localhost:5432/cooplink
TEST_DATABASE_URL=
SQLITE_FOR_DEV=False

# Optional local media serving
SERVE_MEDIA=False

# Cloudflare Turnstile is required for registration and password login.
# These legacy CLOUDFLARE_* names are supported by the current settings file.
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Canonical Turnstile aliases are also supported.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email / Mailtrap / OTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@cooplink.local
SERVER_EMAIL=no-reply@cooplink.local
EMAIL_OTP_EXPIRES_MINUTES=10
